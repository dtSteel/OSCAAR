# ── Application ────────────────────────────────────────
APP_ENV=demo
APP_SECRET_KEY=replace-with-64-char-random-string
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────
# Demo (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./oscaar.db
# Production (PostgreSQL) — uncomment and fill in:
# DATABASE_URL=postgresql+asyncpg://oscaar:password@localhost:5432/oscaar

# ── Vector Store ────────────────────────────────────────
# Demo (ChromaDB):
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_data
# Production (Qdrant) — uncomment and fill in:
# VECTOR_STORE=qdrant
# QDRANT_HOST=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION=oscaar_documents
EMBED_CHUNK_SIZE=512
EMBED_CHUNK_OVERLAP=64
EMBED_TOP_K=5

# ── LLM and Embeddings ──────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL=text-embedding-3-large
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ── Email ───────────────────────────────────────────────
# Demo (Mailpit):
EMAIL_BACKEND=mailpit
EMAIL_FROM=oscaar@oscaar.org
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
# Production (Postal) — uncomment and fill in:
# EMAIL_BACKEND=postal
# POSTAL_API_URL=https://postal.yourdomain.com
# POSTAL_API_KEY=your-postal-api-key

# ── Storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50
# Production (S3) — uncomment and fill in:
# S3_BUCKET=oscaar-documents
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret

# ── GeoIP ───────────────────────────────────────────────
GEOIP_DB_PATH=./GeoLite2-Country.mmdb

# ── Celery / Redis ──────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_CONCURRENCY=2
BATCH_WATCH_DIR=./batch_inbox

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_PER_MINUTE=200
